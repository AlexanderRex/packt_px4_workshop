        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name='right_leg_joint' type='revolute'>
      <parent>base_link</parent>
      <child>right_leg</child>
      <pose>0.00026 0.040515 -0.048 0 0 0</pose>
      <axis>
        <xyz>1 0 0</xyz>
        <limit><lower>0</lower><upper>0</upper></limit>
      </axis>
    </joint>

    <!-- Gimbal mount (static) -->
    <link name="cgo3_mount_link">
      <inertial>
        <pose>-0.041 0 -0.162 0 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
