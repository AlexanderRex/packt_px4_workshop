+void GZBridge::handleFailureInjection()
+{
+	vehicle_command_s cmd;
+
+	while (_vehicle_command_sub.update(&cmd)) {
+		if (cmd.command != vehicle_command_s::VEHICLE_CMD_INJECT_FAILURE) {
+			continue;
+		}
+
+		const auto failure_unit = static_cast<uint32_t>(cmd.param1 + 0.5f);
+		const auto failure_type = static_cast<uint32_t>(cmd.param2 + 0.5f);
+
+		bool handled = true;
+		bool *flag = nullptr;
+
+		switch (failure_unit) {
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_GYRO:
+			flag = &_failure_gyro;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_ACCEL:
+			flag = &_failure_accel;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_MAG:
+			flag = &_failure_mag;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_BARO:
+			flag = &_failure_baro;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_GPS:
+			flag = &_failure_gps;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_AIRSPEED:
+			flag = &_failure_airspeed;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_OPTICAL_FLOW:
+			flag = &_failure_optical_flow;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SENSOR_DISTANCE_SENSOR:
+			flag = &_failure_distance_sensor;
+			break;
+
+		case vehicle_command_s::FAILURE_UNIT_SYSTEM_MOTOR: {
+			const auto instance = static_cast<uint32_t>(cmd.param3 + 0.5f);
+
+			if (failure_type == vehicle_command_s::FAILURE_TYPE_OK) {
+				if (instance == 0) {
+					_mixing_interface_esc._motor_failure_mask = 0;
+				} else {
+					_mixing_interface_esc._motor_failure_mask &= ~(1 << (instance - 1));
+				}
+				PX4_INFO("GZBridge: motor %u restored", instance);
+
+			} else {
+				if (instance == 0) {
+					_mixing_interface_esc._motor_failure_mask = 0xFF;
+				} else {
+					_mixing_interface_esc._motor_failure_mask |= (1 << (instance - 1));
+				}
+				PX4_WARN("GZBridge: motor %u failure injected (type %u)", instance, failure_type);
+			}
+
+			vehicle_command_ack_s ack{};
+			ack.command = cmd.command;
+			ack.result = vehicle_command_ack_s::VEHICLE_CMD_RESULT_ACCEPTED;
+			ack.from_external = false;
+			ack.timestamp = hrt_absolute_time();
+			_vehicle_command_ack_pub.publish(ack);
+			continue;
+		}
+
+		default:
+			handled = false;
+			break;
+		}
+
+		if (handled && flag) {
+			if (failure_type == vehicle_command_s::FAILURE_TYPE_OK) {
+				*flag = false;
+				PX4_INFO("GZBridge: sensor %u restored", failure_unit);
+
+			} else {
+				*flag = true;
+				PX4_WARN("GZBridge: sensor %u failure injected (type %u)", failure_unit, failure_type);
+			}
+
+			vehicle_command_ack_s ack{};
+			ack.command = cmd.command;
+			ack.result = vehicle_command_ack_s::VEHICLE_CMD_RESULT_ACCEPTED;
+			ack.from_external = false;
+			ack.timestamp = hrt_absolute_time();
+			_vehicle_command_ack_pub.publish(ack);
+		}
+	}
+}
